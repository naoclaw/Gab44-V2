# =============================================================
# Gab44 Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env file.
# =============================================================

# URL of the running backend API (no trailing slash)
REACT_APP_BACKEND_URL=http://localhost:8001

# OneSignal Web Push App ID
# Must match the App ID configured in your OneSignal dashboard.
# This is injected into public/index.html at build time.
REACT_APP_ONESIGNAL_APP_ID=e143a4a3-a485-40a8-b665-31d21a1b1de7
