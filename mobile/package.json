{
  "name": "gab44-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor mobile shell wrapping the Gab44 React 19 SPA. See ./README.md.",
  "scripts": {
    "build:web": "cd ../frontend && npm install && npm run build",
    "sync": "cap sync",
    "android:add": "cap add android",
    "android:open": "cap open android",
    "android:run": "cap run android",
    "ios:add": "cap add ios",
    "ios:open": "cap open ios",
    "ios:run": "cap run ios",
    "build:android": "npm run build:web && cap sync android && cap open android",
    "doctor": "cap doctor"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.0"
  }
}
