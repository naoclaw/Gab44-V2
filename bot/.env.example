# Gab44 Telegram Bot — environment variables
# Copy to .env (do NOT commit) and fill in.

# From @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Random 32-char string. Required for webhook mode.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# polling | webhook
BOT_MODE=polling

# When BOT_MODE=webhook, this is the public HTTPS URL Traefik routes to us.
# Telegram will POST to ${BOT_WEBHOOK_BASE}/webhook/${TELEGRAM_WEBHOOK_SECRET}
BOT_WEBHOOK_BASE=https://bot.gab44.com
BOT_WEBHOOK_PORT=8080

# Backend FastAPI base URL. In docker-compose this is "http://api:8001".
BACKEND_URL=http://localhost:8001

# Service token used by the bot to authenticate to the backend's
# /api/internal/* surface and the new /api/auth/telegram-link endpoint.
# Same value must be set in the backend's environment.
SERVICE_TOKEN=

# Optional Sentry DSN — if set, handler exceptions are reported.
SENTRY_DSN=
