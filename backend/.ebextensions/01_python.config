option_settings:
  # Use the Procfile to start uvicorn (ASGI) instead of the default WSGI server.
  # The Procfile in this directory defines: web: uvicorn server:app ...
  aws:elasticbeanstalk:container:python:
    WSGIPath: server:app

  # Proxy timeout — allow up to 120 s for AI / Swiss Ephemeris calls.
  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

  aws:elasticbeanstalk:environment:
    EnvironmentType: SingleInstance

  # Health check
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /api/health
