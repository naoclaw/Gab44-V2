# =============================================================
# Gab44 Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env file.
# =============================================================

# ── Database (required) ──────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=gab44

# ── Auth (required) ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Admin access ─────────────────────────────────────────────
# Comma-separated email addresses that receive admin role on login
ADMIN_EMAILS=admin@yourdomain.com

# ── Frontend URL (used in email links) ───────────────────────
FRONTEND_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────
# In production: set to your actual frontend domain
CORS_ORIGINS=http://localhost:3000

# ── OpenAI (AI guidance, coach, compatibility) ────────────────
OPENAI_API_KEY=sk-proj-...

# ── SendGrid (transactional + marketing email) ────────────────
SENDGRID_API_KEY=SG....
# These are the "From" addresses for each email type.
# All must be verified senders in your SendGrid account.
EMAIL_NOREPLY=noreply@yourdomain.com
EMAIL_VERIFY=verify@yourdomain.com
EMAIL_SUPPORT=support@yourdomain.com
EMAIL_MARKETING=hello@yourdomain.com

# ── Stripe (payments) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get this from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OneSignal (push notifications) ───────────────────────────
ONESIGNAL_APP_ID=e143a4a3-a485-40a8-b665-31d21a1b1de7
ONESIGNAL_API_KEY=os_v2_app_...

# ── Mapbox (city geocoding autocomplete) ─────────────────────
# Optional — if not set the app falls back to a 327-city static database.
# Get a free token at https://account.mapbox.com/
MAPBOX_ACCESS_TOKEN=pk.eyJ1IjoiLi4uIn0...
